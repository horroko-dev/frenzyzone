<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ '/css/style.css' | url }}">
<script>
(function() {
  var stored = localStorage.getItem('fz-lang');
  var isDE = location.pathname.indexOf('/de') !== -1;
  var current = isDE ? 'de' : 'en';
  if (!stored) {
    var lang = (navigator.language || '').toLowerCase().indexOf('de') === 0 ? 'de' : 'en';
    if (lang !== current) {
      localStorage.setItem('fz-lang', lang);
      location.replace(lang === 'de' ? '{{ "/de/" | url }}' : '{{ "/" | url }}');
      return;
    }
    localStorage.setItem('fz-lang', current);
  } else if (stored !== current) {
    location.replace(stored === 'de' ? '{{ "/de/" | url }}' : '{{ "/" | url }}');
    return;
  }
})();
</script>
</head>
<body>

{% include "components/icons.njk" %}
<canvas id="particles"></canvas>

<div class="lang-switch">
  <a href="{{ '/' | url }}" class="lang-link{{ ' active' if locale == 'en' }}" data-lang="en">EN</a>
  <span class="lang-sep">|</span>
  <a href="{{ '/de/' | url }}" class="lang-link{{ ' active' if locale == 'de' }}" data-lang="de">DE</a>
</div>

<nav class="nav" id="nav">
  <a href="#synergy"><svg class="nav-icon"><use href="#icon-star"/></svg>{{ i18n[locale].nav.synergy }}</a>
  <a href="#leveling"><svg class="nav-icon"><use href="#icon-scroll"/></svg>{{ i18n[locale].nav.leveling }}</a>
  <a href="#gear"><svg class="nav-icon"><use href="#icon-weapon"/></svg>{{ i18n[locale].nav.gear }}</a>
  <a href="#attributes"><svg class="nav-icon"><use href="#icon-strength"/></svg>{{ i18n[locale].nav.stats }}</a>
  <a href="#mercs"><svg class="nav-icon"><use href="#icon-armor"/></svg>{{ i18n[locale].nav.mercs }}</a>
  <a href="#charms"><svg class="nav-icon"><use href="#icon-charm"/></svg>{{ i18n[locale].nav.charms }}</a>
  <a href="#farming"><svg class="nav-icon"><use href="#icon-map"/></svg>{{ i18n[locale].nav.farming }}</a>
  <a href="#tips"><svg class="nav-icon"><use href="#icon-campfire"/></svg>{{ i18n[locale].nav.tips }}</a>
</nav>

{{ content | safe }}

<div class="watermark" data-mode-target="watermark" aria-hidden="true">
  <svg><use href="#icon-watermark-weapons"/></svg>
</div>

<footer class="footer">
  <p>{{ i18n[locale].footer.site | safe }}</p>
  <p class="disclaimer">{{ i18n[locale].footer.disclaimer }}</p>
</footer>

<script type="application/json" id="mode-data">
{
  "barb": {
    "heroLines": {
      "barb": { "visible": true, "order": 1 },
      "necro": { "visible": false, "order": 2 },
      "mid": { "visible": false, "order": 3 },
      "zon": { "visible": false, "order": 4 }
    },
    "heroIcons": { "left": "barb", "right": null },
    "watermark": "watermark-axe",
    "tagline": "{{ i18n[locale].taglines.barb }}",
    "synergyHeader": {
      "label": "{{ synergy.header.default.label }}",
      "title": "{{ synergy.header.default.title }}",
      "desc": "{{ synergy.header.default.desc }}"
    },
    "synergyCards": ["barb"],
    "synergyBottom": false
  },
  "zon": {
    "heroLines": {
      "barb": { "visible": false, "order": 1 },
      "necro": { "visible": false, "order": 2 },
      "mid": { "visible": false, "order": 3 },
      "zon": { "visible": true, "order": 4 }
    },
    "heroIcons": { "left": null, "right": "zon" },
    "watermark": "watermark-javelin",
    "tagline": "{{ i18n[locale].taglines.zon }}",
    "synergyHeader": {
      "label": "{{ synergy.header.default.label }}",
      "title": "{{ synergy.header.default.title }}",
      "desc": "{{ synergy.header.default.desc }}"
    },
    "synergyCards": ["zon"],
    "synergyBottom": false
  },
  "default": {
    "heroLines": {
      "barb": { "visible": true, "order": 1 },
      "necro": { "visible": false, "order": 2 },
      "mid": { "visible": true, "order": 3 },
      "zon": { "visible": true, "order": 4 }
    },
    "heroIcons": { "left": "barb", "right": "zon" },
    "watermark": "watermark-weapons",
    "tagline": "{{ i18n[locale].taglines.default }}",
    "synergyHeader": {
      "label": "{{ synergy.header.default.label }}",
      "title": "{{ synergy.header.default.title }}",
      "desc": "{{ synergy.header.default.desc }}"
    },
    "synergyCards": ["barb", "zon"],
    "synergyBottom": true,
    "synergy": {
      "title": "{{ synergy.combined.title }}",
      "summary": "{{ synergy.combined.summary }}",
      "stats": [
        {%- for stat in synergy.combined.stats %}
        { "value": "{{ stat.value }}", "label": "{{ stat.label }}" }{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "mercStrategy": {
      "title": "{{ mercs.duo_strategy.title }}",
      "points": [
        {%- for point in mercs.duo_strategy.points %}
        "{{ point }}"{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "farmStrategies": {
      {%- for farm in farming %}
      "{{ farm.zone }}": {
        "text": "{{ farm.strategy }}",
        "icons": ["barb", "zon"]
      }{{ "," if not loop.last }}
      {%- endfor %}
    },
    "tips": [
      {%- for tip in tips.default %}
      { "numeral": "{{ tip.numeral }}", "icon": "{{ tip.icon }}", "title": "{{ tip.title }}", "body": "{{ tip.body }}" }{{ "," if not loop.last }}
      {%- endfor %}
    ]
  },
  "affair": {
    "heroLines": {
      "barb": { "visible": false, "order": 1 },
      "necro": { "visible": true, "order": 1 },
      "mid": { "visible": true, "order": 2 },
      "zon": { "visible": true, "order": 3 }
    },
    "heroIcons": { "left": "necro", "right": "zon" },
    "watermark": "watermark-affair",
    "tagline": "{{ i18n[locale].taglines.affair }}",
    "synergyHeader": {
      "label": "{{ synergy.header.affair.label }}",
      "title": "{{ synergy.header.affair.title }}",
      "desc": "{{ synergy.header.affair.desc }}"
    },
    "synergyCards": ["necro", "zon"],
    "synergyBottom": true,
    "synergy": {
      "title": "{{ synergy.combined_affair.title }}",
      "summary": "{{ synergy.combined_affair.summary }}",
      "stats": [
        {%- for stat in synergy.combined_affair.stats %}
        { "value": "{{ stat.value }}", "label": "{{ stat.label }}" }{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "mercStrategy": {
      "title": "{{ mercs.duo_strategy_affair.title }}",
      "points": [
        {%- for point in mercs.duo_strategy_affair.points %}
        "{{ point }}"{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "farmStrategies": {
      {%- for farm in farming %}
      "{{ farm.zone }}": {
        "text": "{{ farm.strategy_affair }}",
        "icons": ["necro", "zon"]
      }{{ "," if not loop.last }}
      {%- endfor %}
    },
    "tips": [
      {%- for tip in tips.affair %}
      { "numeral": "{{ tip.numeral }}", "icon": "{{ tip.icon }}", "title": "{{ tip.title }}", "body": "{{ tip.body }}" }{{ "," if not loop.last }}
      {%- endfor %}
    ]
  },
  "rainbow": {
    "heroLines": {
      "barb": { "visible": true, "order": 1 },
      "necro": { "visible": true, "order": 3 },
      "mid": { "visible": true, "order": 2 },
      "zon": { "visible": false, "order": 4 }
    },
    "heroIcons": { "left": "barb", "right": "necro" },
    "watermark": "watermark-rainbow",
    "tagline": "{{ i18n[locale].taglines.rainbow }}",
    "synergyHeader": {
      "label": "{{ synergy.header.rainbow.label }}",
      "title": "{{ synergy.header.rainbow.title }}",
      "desc": "{{ synergy.header.rainbow.desc }}"
    },
    "synergyCards": ["barb", "necro"],
    "synergyBottom": true,
    "synergy": {
      "title": "{{ synergy.combined_rainbow.title }}",
      "summary": "{{ synergy.combined_rainbow.summary }}",
      "stats": [
        {%- for stat in synergy.combined_rainbow.stats %}
        { "value": "{{ stat.value }}", "label": "{{ stat.label }}" }{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "mercStrategy": {
      "title": "{{ mercs.duo_strategy_rainbow.title }}",
      "points": [
        {%- for point in mercs.duo_strategy_rainbow.points %}
        "{{ point }}"{{ "," if not loop.last }}
        {%- endfor %}
      ]
    },
    "farmStrategies": {
      {%- for farm in farming %}
      "{{ farm.zone }}": {
        "text": "{{ farm.strategy_rainbow }}",
        "icons": ["barb", "necro"]
      }{{ "," if not loop.last }}
      {%- endfor %}
    },
    "tips": [
      {%- for tip in tips.rainbow %}
      { "numeral": "{{ tip.numeral }}", "icon": "{{ tip.icon }}", "title": "{{ tip.title }}", "body": "{{ tip.body }}" }{{ "," if not loop.last }}
      {%- endfor %}
    ]
  }
}
</script>
<script src="{{ '/js/main.js' | url }}"></script>
</body>
</html>
