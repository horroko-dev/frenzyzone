<div class="build-card {{ 'barb-card' if side == 'barb' else 'zon-card' }}">
  <span class="class-label">{{ label }}</span>
  <h4>{{ i18n[locale].components.skills }}</h4>
  <ul class="skill-list">
    {%- for skill in skills %}
    <li><span class="skill-name">{{ skill.name }}</span><span class="skill-pts">{{ skill.pts }}</span></li>
    {%- endfor %}
  </ul>
  <h4>{{ i18n[locale].components.strategy }}</h4>
  <p class="stat-alloc">{{ strategy }}</p>
</div>
