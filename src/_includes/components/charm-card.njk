<div class="charm-card {{ side }}-card">
  <span class="class-label"><svg class="class-icon"><use href="#icon-{{ side }}"/></svg>{{ data.label }}</span>
  {%- for group in data.inventory %}
  <div class="charm-group">
    <div class="charm-group-header">
      <h4><svg class="slot-icon"><use href="#icon-charm"/></svg>{{ group.slot }}</h4>
      <span class="charm-size">{{ group.size }}</span>
    </div>
    {%- for item in group.items %}
    <div class="gear-item {{ item.rarity }}">{{ item.name }}{% if item.note %} <span class="note">&mdash; {{ item.note }}</span>{% endif %}</div>
    {%- endfor %}
  </div>
  {%- endfor %}
  {% if data.notes %}
  <div class="stat-notes">{{ data.notes }}</div>
  {% endif %}
</div>
