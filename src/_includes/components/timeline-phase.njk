<div class="timeline-phase">
  <div class="timeline-marker"></div>
  <div class="phase-header">
    <span class="phase-level">{{ phase.level }}</span>
    <h3 class="phase-name">{{ phase.name }}</h3>
  </div>
  <div class="phase-content">
    <div class="build-card barb-card">
      <span class="class-label"><svg class="class-icon"><use href="#icon-barb"/></svg>{{ i18n[locale].classes.barb }}</span>
      <h4><svg class="slot-icon"><use href="#icon-scroll"/></svg>{{ i18n[locale].components.skills }}</h4>
      <ul class="skill-list">
        {%- for skill in phase.barb.skills %}
        <li><span class="skill-name">{{ skill.name }}</span><span class="skill-pts">{{ skill.pts }}</span></li>
        {%- endfor %}
      </ul>
      <h4><svg class="slot-icon"><use href="#icon-campfire"/></svg>{{ i18n[locale].components.strategy }}</h4>
      <p class="stat-alloc">{{ phase.barb.strategy }}</p>
    </div>
    <div class="build-card necro-card">
      <span class="class-label"><svg class="class-icon"><use href="#icon-necro"/></svg>{{ i18n[locale].classes.necro }}</span>
      <h4><svg class="slot-icon"><use href="#icon-scroll"/></svg>{{ i18n[locale].components.skills }}</h4>
      <ul class="skill-list">
        {%- for skill in phase.necro.skills %}
        <li><span class="skill-name">{{ skill.name }}</span><span class="skill-pts">{{ skill.pts }}</span></li>
        {%- endfor %}
      </ul>
      <h4><svg class="slot-icon"><use href="#icon-campfire"/></svg>{{ i18n[locale].components.strategy }}</h4>
      <p class="stat-alloc">{{ phase.necro.strategy }}</p>
    </div>
    <div class="build-card zon-card">
      <span class="class-label"><svg class="class-icon"><use href="#icon-zon"/></svg>{{ i18n[locale].classes.zon }}</span>
      <h4><svg class="slot-icon"><use href="#icon-scroll"/></svg>{{ i18n[locale].components.skills }}</h4>
      <ul class="skill-list">
        {%- for skill in phase.zon.skills %}
        <li><span class="skill-name">{{ skill.name }}</span><span class="skill-pts">{{ skill.pts }}</span></li>
        {%- endfor %}
      </ul>
      <h4><svg class="slot-icon"><use href="#icon-campfire"/></svg>{{ i18n[locale].components.strategy }}</h4>
      <p class="stat-alloc">{{ phase.zon.strategy }}</p>
    </div>
  </div>
</div>
