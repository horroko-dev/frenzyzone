  </div>

  <div class="farm-filters">
    <button class="farm-filter active" data-filter="all">{{ i18n[locale].farmFilters.all }}</button>
    <button class="farm-filter" data-filter="essential">{{ i18n[locale].farmFilters.essential }}</button>
    <button class="farm-filter" data-filter="high">{{ i18n[locale].farmFilters.high }}</button>
