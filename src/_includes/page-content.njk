</section>

<div class="divider"></div>

{# ========== TIPS ========== #}
<section id="tips">
  <div class="section-header">
    <svg class="section-icon"><use href="#icon-campfire"/></svg>
    <p class="section-label">{{ i18n[locale].sections.tips.label }}</p>
    <h2 class="section-title">{{ i18n[locale].sections.tips.title }}</h2>
    <div class="section-rule"></div>
    <p class="section-desc">{{ i18n[locale].sections.tips.desc | safe }}</p>
  </div>

  <div class="tips-grid" data-mode-target="tips">
    {%- for tip in tips.default %}
    {% set tip = tip %}
    {% include "components/tip-card.njk" %}
    {%- endfor %}
  </div>
</section>
