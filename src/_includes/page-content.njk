  <div class="section-header">
    <svg class="section-icon"><use href="#icon-armor"/></svg>
    <p class="section-label">{{ i18n[locale].sections.mercs.label }}</p>
    <h2 class="section-title">{{ i18n[locale].sections.mercs.title }}</h2>
    <div class="section-rule"></div>
    <p class="section-desc">{{ i18n[locale].sections.mercs.desc | safe }}</p>
  </div>

  <div class="dual-panel">
    {% set data = mercs.barb %}
    {% set side = "barb" %}
    {% include "components/merc-card.njk" %}
    {% set data = mercs.necro %}
    {% set side = "necro" %}
    {% include "components/merc-card.njk" %}
    {% set data = mercs.zon %}
    {% set side = "zon" %}
    {% include "components/merc-card.njk" %}
    <div class="merc-strategy" data-mode-target="mercStrategy">
      <h3>{{ mercs.duo_strategy.title }}</h3>
      <ul>
        {%- for point in mercs.duo_strategy.points %}
        <li>{{ point }}</li>
        {%- endfor %}
      </ul>
    </div>
  </div>
</section>

<div class="divider"></div>

